<%- include('partials/header') %>

<div class="login-page d-flex align-items-center justify-content-center min-vh-100">
  <div class="login-card card shadow-lg border-0" style="width:100%;max-width:420px;">
    <div class="card-body p-5">
      <!-- Logo -->
      <div class="text-center mb-4">
        <div class="login-logo mx-auto mb-3">
          <i class="bi bi-shield-lock-fill" style="font-size:2.2rem;color:var(--accent);"></i>
        </div>
        <h4 class="fw-bold mb-0" style="color:#fff;">Panel Admin</h4>
        <p class="text-muted small">Akses terbatas untuk administrator</p>
      </div>

      <!-- Flash messages -->
      <% if (error && error.length) { %>
        <div class="alert alert-danger alert-dismissible alert-auto-dismiss fade show" role="alert">
          <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error[0] %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>
      <% if (success && success.length) { %>
        <div class="alert alert-success alert-dismissible alert-auto-dismiss fade show" role="alert">
          <i class="bi bi-check-circle-fill me-2"></i><%= success[0] %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <!-- Form -->
      <form action="/login" method="POST" novalidate>
        <div class="mb-3">
          <label class="form-label fw-semibold" for="id_admin">ID Admin</label>
          <div class="input-group">
            <span class="input-group-text border-end-0" style="border-radius:10px 0 0 10px !important;">
              <i class="bi bi-person" style="color:var(--accent);"></i>
            </span>
            <input
              type="text"
              id="id_admin"
              name="id_admin"
              class="form-control border-start-0 ps-0"
              placeholder="Masukkan ID Admin"
              required
              autocomplete="username"
              style="border-radius:0 10px 10px 0 !important;"
            />
          </div>
        </div>

        <div class="mb-4">
          <label class="form-label fw-semibold" for="password">Password</label>
          <div class="input-group">
            <span class="input-group-text border-end-0" style="border-radius:10px 0 0 10px !important;">
              <i class="bi bi-lock" style="color:var(--accent);"></i>
            </span>
            <input
              type="password"
              id="password"
              name="password"
              class="form-control border-start-0 ps-0"
              placeholder="Masukkan password admin"
              required
              autocomplete="current-password"
            />
            <button type="button" class="btn border border-start-0" id="togglePassword" tabindex="-1"
              style="background:var(--input-bg);border-color:var(--input-border)!important;border-radius:0 10px 10px 0 !important;">
              <i class="bi bi-eye-slash" id="eyeIcon" style="color:var(--text-muted);"></i>
            </button>
          </div>
        </div>

        <button type="submit" class="btn btn-warning w-100 fw-bold py-2" style="border-radius:12px!important;font-size:1rem;letter-spacing:.02em;">
          <i class="bi bi-box-arrow-in-right me-2"></i>Masuk sebagai Admin
        </button>
      </form>
    </div>

    <div class="card-footer text-center text-muted small py-3 bg-transparent border-0">
      &copy; <%= new Date().getFullYear() %> e-HMTI &mdash; Himpunan Mahasiswa Teknik Informatika
    </div>
  </div>
</div>

<script>
  document.getElementById('togglePassword').addEventListener('click', function () {
    const pwd  = document.getElementById('password');
    const icon = document.getElementById('eyeIcon');
    if (pwd.type === 'password') {
      pwd.type = 'text';
      icon.classList.replace('bi-eye', 'bi-eye-slash');
    } else {
      pwd.type = 'password';
      icon.classList.replace('bi-eye-slash', 'bi-eye');
    }
  });
</script>

<%- include('partials/footer') %>
